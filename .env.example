# Monitor UI + API port (serves all /_monitor/* endpoints)
MONITOR_LISTEN_ADDR=:9090

# Comma-separated list of llama.cpp backend URLs to proxy to.
BACKEND_URLS=http://host.docker.internal:8080

# Comma-separated listen addresses for each backend (one per BACKEND_URLS entry).
LISTEN_ADDRS=:9091

# Allow per-request backend override via X-Backend-URL header or ?backend= query param.
ALLOW_DYNAMIC_BACKEND=true

# Set to 0 or a negative value to disable automatic cleanup.
RETENTION_DAYS=14
MAX_REQUEST_BYTES=33554432
MAX_CAPTURE_BYTES=33554432
REQUEST_TIMEOUT_SECONDS=600
POLL_BACKEND_METRICS=true
POLL_INTERVAL_SECONDS=10
